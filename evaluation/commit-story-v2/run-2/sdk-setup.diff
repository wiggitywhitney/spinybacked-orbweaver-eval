+// ABOUTME: OpenTelemetry SDK initialization for commit-story-v2.
+// ABOUTME: Bootstraps the NodeSDK with instrumentation array for the telemetry agent to populate.
+
+const { NodeSDK } = require('@opentelemetry/sdk-node');
+const { TraceloopNodeServerSdk } = require('@traceloop/node-server-sdk');
+
+const sdk = new NodeSDK({
+  instrumentations: [new TraceloopNodeServerSdk()],
+});
+
+sdk.start();
